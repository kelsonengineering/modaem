# Makefile for ModAEM (Analytic Element Model for groundwater flow)
# Originally generated by mkmf.pl; subsequently hand-maintained.
#
# Usage:
#   make           -- build the modaem executable (default)
#   make clean     -- remove all object files, module files, and the executable
#   make install   -- copy modaem to ~/bin
#   make localize  -- copy all source files into the current directory
#   make tags      -- generate ctags index
#   make TAGS      -- generate etags index

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------

# SRCROOT: directory containing the Fortran source files
SRCROOT = .

# POLYPACK: third-party polygon clipping library (Fortran 77)
POLYPACK = dependencies/polypack

# BUILDDIR: all compiler outputs (.o and .mod) are written here to keep the
# source tree clean.  The directory is created automatically if absent.
BUILDDIR = build

# -----------------------------------------------------------------------------
# Compiler and linker
# -----------------------------------------------------------------------------

FC = gfortran
LD = gfortran

# -O3 -ftree-vectorize: aggressive optimisation with auto-vectorisation
# -I$(BUILDDIR): tell gfortran where to find .mod files written by earlier
#                compilation units (required because modules land in BUILDDIR)
# -J$(BUILDDIR): direct gfortran to write .mod files into BUILDDIR instead of
#                the current directory
#FFLAGS = -O2
FFLAGS = -O3 -ftree-vectorize -I$(BUILDDIR) -J$(BUILDDIR)

# macOS only: link against the Accelerate framework for BLAS/LAPACK routines
# used by u_matrix.  Replace with -llapack -lblas on Linux.
LDFLAGS = -framework Accelerate

# CPPDEFS, CPPFLAGS, OTHERFLAGS are intentionally left empty here; they can be
# supplied on the make command line (e.g. make CPPDEFS=-DDEBUG).

# -----------------------------------------------------------------------------
# Default goal
# -----------------------------------------------------------------------------

.DEFAULT:

all: $(BUILDDIR) modaem

# Create BUILDDIR before any compilation rule runs
$(BUILDDIR):
	mkdir -p $(BUILDDIR)

# -----------------------------------------------------------------------------
# Compilation rules
# Module tiers (compile order enforced by dependencies):
#   u_*  -- utility layer (constants, I/O, maths, matrix, polygon)
#   i_*  -- influence-function layer (pure complex-analysis kernels)
#   f_*  -- storage/dispatch layer (element collections + GetInfluence API)
#   m_*  -- physical model layer (element strings, aquifer, AEM driver)
#   a_*  -- analysis layer (grid output, tracelines, observations, stdio)
#   modaem -- top-level driver
# polypack -- third-party polygon library (Fortran 77, no module)
# -----------------------------------------------------------------------------

# -- utility --
$(BUILDDIR)/u_constants.o: $(SRCROOT)/u_constants.F90
	$(FC) $(CPPDEFS) $(CPPFLAGS) $(FFLAGS) $(OTHERFLAGS) -c	$(SRCROOT)/u_constants.F90 -o $@
$(BUILDDIR)/u_io.o: $(SRCROOT)/u_io.F90 $(BUILDDIR)/u_constants.o
	$(FC) $(CPPDEFS) $(CPPFLAGS) $(FFLAGS) $(OTHERFLAGS) -c	$(SRCROOT)/u_io.F90 -o $@
$(BUILDDIR)/u_math.o: $(SRCROOT)/u_math.F90 $(BUILDDIR)/u_constants.o
	$(FC) $(CPPDEFS) $(CPPFLAGS) $(FFLAGS) $(OTHERFLAGS) -c	$(SRCROOT)/u_math.F90 -o $@
$(BUILDDIR)/u_matrix.o: $(SRCROOT)/u_matrix.F90 $(BUILDDIR)/u_constants.o $(BUILDDIR)/u_io.o
	$(FC) $(CPPDEFS) $(CPPFLAGS) $(FFLAGS) $(OTHERFLAGS) -c	$(SRCROOT)/u_matrix.F90 -o $@
$(BUILDDIR)/u_grid.o: $(SRCROOT)/u_grid.F90 $(BUILDDIR)/u_constants.o $(BUILDDIR)/u_io.o
	$(FC) $(CPPDEFS) $(CPPFLAGS) $(FFLAGS) $(OTHERFLAGS) -c	$(SRCROOT)/u_grid.F90 -o $@
$(BUILDDIR)/polypack.o: $(POLYPACK)/polypack.f
	$(FC) $(CPPDEFS) $(CPPFLAGS) $(FFLAGS) $(OTHERFLAGS) -c	$(POLYPACK)/polypack.f -o $@
$(BUILDDIR)/u_polygon.o: $(SRCROOT)/u_polygon.F90 $(BUILDDIR)/u_constants.o $(BUILDDIR)/polypack.o
	$(FC) $(CPPDEFS) $(CPPFLAGS) $(FFLAGS) $(OTHERFLAGS) -c	$(SRCROOT)/u_polygon.F90 -o $@
$(BUILDDIR)/u_domain.o: $(SRCROOT)/u_domain.F90 $(BUILDDIR)/u_constants.o $(BUILDDIR)/u_io.o $(BUILDDIR)/u_polygon.o
	$(FC) $(CPPDEFS) $(CPPFLAGS) $(FFLAGS) $(OTHERFLAGS) -c	$(SRCROOT)/u_domain.F90 -o $@

# -- influence-function layer --
$(BUILDDIR)/i_areasink.o: $(SRCROOT)/i_areasink.F90 $(BUILDDIR)/u_constants.o
	$(FC) $(CPPDEFS) $(CPPFLAGS) $(FFLAGS) $(OTHERFLAGS) -c	$(SRCROOT)/i_areasink.F90 -o $@
$(BUILDDIR)/i_dipole.o: $(SRCROOT)/i_dipole.F90 $(BUILDDIR)/u_constants.o
	$(FC) $(CPPDEFS) $(CPPFLAGS) $(FFLAGS) $(OTHERFLAGS) -c	$(SRCROOT)/i_dipole.F90 -o $@
$(BUILDDIR)/i_linesink.o: $(SRCROOT)/i_linesink.F90 $(BUILDDIR)/u_constants.o
	$(FC) $(CPPDEFS) $(CPPFLAGS) $(FFLAGS) $(OTHERFLAGS) -c	$(SRCROOT)/i_linesink.F90 -o $@
$(BUILDDIR)/i_pond.o: $(SRCROOT)/i_pond.F90 $(BUILDDIR)/u_constants.o
	$(FC) $(CPPDEFS) $(CPPFLAGS) $(FFLAGS) $(OTHERFLAGS) -c	$(SRCROOT)/i_pond.F90 -o $@
$(BUILDDIR)/i_well.o: $(SRCROOT)/i_well.F90 $(BUILDDIR)/u_constants.o
	$(FC) $(CPPDEFS) $(CPPFLAGS) $(FFLAGS) $(OTHERFLAGS) -c	$(SRCROOT)/i_well.F90 -o $@

# -- storage/dispatch layer --
$(BUILDDIR)/f_bwl.o: $(SRCROOT)/f_bwl.F90 $(BUILDDIR)/u_constants.o $(BUILDDIR)/u_io.o $(BUILDDIR)/i_well.o $(BUILDDIR)/u_math.o
	$(FC) $(CPPDEFS) $(CPPFLAGS) $(FFLAGS) $(OTHERFLAGS) -c	$(SRCROOT)/f_bwl.F90 -o $@
$(BUILDDIR)/f_dipole.o: $(SRCROOT)/f_dipole.F90 $(BUILDDIR)/u_constants.o $(BUILDDIR)/u_io.o $(BUILDDIR)/i_dipole.o $(BUILDDIR)/i_linesink.o
	$(FC) $(CPPDEFS) $(CPPFLAGS) $(FFLAGS) $(OTHERFLAGS) -c	$(SRCROOT)/f_dipole.F90 -o $@
$(BUILDDIR)/f_linesink.o: $(SRCROOT)/f_linesink.F90 $(BUILDDIR)/u_constants.o $(BUILDDIR)/u_io.o $(BUILDDIR)/i_linesink.o
	$(FC) $(CPPDEFS) $(CPPFLAGS) $(FFLAGS) $(OTHERFLAGS) -c	$(SRCROOT)/f_linesink.F90 -o $@
$(BUILDDIR)/f_pond.o: $(SRCROOT)/f_pond.F90 $(BUILDDIR)/u_constants.o $(BUILDDIR)/u_io.o $(BUILDDIR)/i_pond.o
	$(FC) $(CPPDEFS) $(CPPFLAGS) $(FFLAGS) $(OTHERFLAGS) -c	$(SRCROOT)/f_pond.F90 -o $@
$(BUILDDIR)/f_well.o: $(SRCROOT)/f_well.F90 $(BUILDDIR)/u_constants.o $(BUILDDIR)/u_io.o $(BUILDDIR)/i_well.o
	$(FC) $(CPPDEFS) $(CPPFLAGS) $(FFLAGS) $(OTHERFLAGS) -c	$(SRCROOT)/f_well.F90 -o $@

# -- physical model layer --
$(BUILDDIR)/m_aqu.o: $(SRCROOT)/m_aqu.F90 $(BUILDDIR)/u_constants.o $(BUILDDIR)/u_io.o $(BUILDDIR)/u_matrix.o $(BUILDDIR)/u_polygon.o $(BUILDDIR)/u_domain.o $(BUILDDIR)/f_dipole.o $(BUILDDIR)/i_linesink.o
	$(FC) $(CPPDEFS) $(CPPFLAGS) $(FFLAGS) $(OTHERFLAGS) -c	$(SRCROOT)/m_aqu.F90 -o $@
