# -----------------------------------------------------------------------------
# Targets
# -----------------------------------------------------------------------------

# Link the final executable
modaem: $(OBJ)
	$(LD) $(OBJ) -o modaem  $(LDFLAGS)

install: modaem
	cp -f modaem ~/bin/modaem

# Remove all build artefacts and the executable; leaves source tree clean
clean: neat
	-rm -f .cppdefs $(OBJ) $(BUILDDIR)/*.mod modaem

# Remove any temporary files recorded in TMPFILES (none defined by default)
neat:
	-rm -f $(TMPFILES)

# Copy all source files into the current directory (useful for out-of-tree work)
localize: $(SRC)
	cp $(SRC) .

TAGS: $(SRCROOT)
	etags $(SRCROOT)

tags: $(SRCROOT)
	ctags $(SRCROOT)
